/* ===== 编辑风字体配对 ===== */
/* 标题: Playfair Display (优雅衬线) */
/* 正文: Source Sans 3 (干净无衬线) */
/* 代码: JetBrains Mono */

$content-desktop-large = 960px
$content-desktop-largest = 65%

/* 配色 */
$brand-color = #c45c3c
$brand-hover = #1a1a1a

/* 字体 — 通过 CDN 引入 */
$font-family-base = "Source Sans 3", "Noto Sans SC", -apple-system, BlinkMacSystemFont, sans-serif
$font-family-headings = "Playfair Display", "Noto Serif SC", Georgia, serif
$font-family-mono = "JetBrains Mono", "Fira Code", monospace

/* 标题字号放大 */
$font-size-headings-base = 28px
$font-size-headings-step = 4px
