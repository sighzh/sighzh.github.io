/* ===== 编辑风字体配对 ===== */
/* 标题: Noto Serif SC (中文衬线) + Source Serif 4 (英文衬线) */
/* 正文: Noto Sans SC (中文无衬线) + Source Sans 3 (英文无衬线) */
/* 代码: JetBrains Mono */

$content-desktop-large = 960px
$content-desktop-largest = 72%

/* 配色 */
$brand-color = #c45c3c
$brand-hover = #1a1a1a

/* 字体 */
$font-family-base = "Noto Sans SC", "Source Sans 3", -apple-system, BlinkMacSystemFont, sans-serif
$font-family-headings = "Noto Serif SC", "Source Serif 4", Georgia, serif
$font-family-mono = "JetBrains Mono", "Fira Code", monospace
