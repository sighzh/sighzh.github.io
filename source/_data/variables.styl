/* 内容宽度 */
$content-desktop-large = 1100px
$content-desktop-largest = 72%

/* 主题色 — 紫蓝渐变系 */
$brand-color = #667eea
$brand-hover = #764ba2

/* 字体 */
$font-family-base = -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", "Noto Sans SC", sans-serif
$font-family-headings = $font-family-base
$font-family-mono = "JetBrains Mono", "Fira Code", "Source Code Pro", Menlo, Consolas, monospace
